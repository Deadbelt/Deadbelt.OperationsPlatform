<Window x:Class="Deadbelt.Desktop.Views.CreateProviderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Provider"
        Width="500"
        SizeToContent="Height"
        MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Background}">

  <Border Background="{StaticResource Brush.Surface}"
          BorderBrush="{StaticResource Brush.Border}"
          BorderThickness="1"
          Padding="24">

    <StackPanel>
      <TextBlock Text="Create Provider"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource Brush.TextPrimary}"/>

      <TextBlock Text="Define a Workspace-level host, tool, platform, or service that future workflows can use."
                 FontSize="14"
                 Foreground="{StaticResource Brush.TextSecondary}"
                 TextWrapping="Wrap"
                 Margin="0,6,0,24"/>

      <TextBlock Text="Provider Name"
                 FontSize="12"
                 Foreground="{StaticResource Brush.TextMuted}"
                 Margin="0,0,0,6"/>

      <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Height="34"
               Padding="8,4"
               VerticalContentAlignment="Center"
               Margin="0,0,0,16"/>

      <TextBlock Text="Provider Type"
                 FontSize="12"
                 Foreground="{StaticResource Brush.TextMuted}"
                 Margin="0,0,0,6"/>

      <ComboBox ItemsSource="{Binding ProviderTypes}"
                SelectedItem="{Binding SelectedProviderTypeOption, Mode=TwoWay}"
                DisplayMemberPath="DisplayName"
                Height="34"
                Margin="0,0,0,16"/>

      <Border Background="#3A2424"
              BorderBrush="#6B2E2E"
              BorderThickness="1"
              CornerRadius="6"
              Padding="10"
              Margin="0,0,0,16">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasError}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   TextWrapping="Wrap"/>
      </Border>

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,8,0,0">
        <Button Content="Cancel"
                Style="{StaticResource SecondaryButton}"
                Width="110"
                Height="36"
                Margin="0,0,10,0"
                IsCancel="True"
                Click="CancelButton_Click"/>

        <Button Content="Create Provider"
                Style="{StaticResource PrimaryButton}"
                Width="150"
                Height="36"
                IsDefault="True"
                Click="CreateButton_Click"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
