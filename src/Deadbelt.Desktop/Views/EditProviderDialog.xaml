<Window x:Class="Deadbelt.Desktop.Views.EditProviderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Provider"
        Width="560"
        SizeToContent="Height"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Background}">

  <Border Background="{StaticResource Brush.Surface}"
          BorderBrush="{StaticResource Brush.Border}"
          BorderThickness="1"
          Padding="24">

    <StackPanel>
      <TextBlock Text="Edit Provider"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource Brush.TextPrimary}"/>

      <TextBlock Text="Update Provider display metadata. The Provider ID and folder path remain unchanged."
                 FontSize="14"
                 Foreground="{StaticResource Brush.TextSecondary}"
                 TextWrapping="Wrap"
                 Margin="0,6,0,24"/>

      <TextBlock Text="Provider Name"
                 FontSize="12"
                 Foreground="{StaticResource Brush.TextMuted}"
                 Margin="0,0,0,6"/>

      <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Height="34"
               Padding="8,4"
               VerticalContentAlignment="Center"
               Margin="0,0,0,16"/>

      <TextBlock Text="Provider Type"
                 FontSize="12"
                 Foreground="{StaticResource Brush.TextMuted}"
                 Margin="0,0,0,6"/>

      <ComboBox ItemsSource="{Binding ProviderTypes}"
                SelectedItem="{Binding SelectedProviderTypeOption, Mode=TwoWay}"
                DisplayMemberPath="DisplayName"
                Height="34"
                Margin="0,0,0,18"/>

      <Border Background="#22272E"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="12"
              Margin="0,0,0,18">

        <StackPanel>
          <TextBlock Text="Immutable Metadata"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource Brush.TextPrimary}"
                     Margin="0,0,0,10"/>

          <TextBlock Text="Provider ID"
                     FontSize="12"
                     Foreground="{StaticResource Brush.TextMuted}"/>

          <TextBlock Text="{Binding ProviderId}"
                     FontSize="12"
                     Foreground="{StaticResource Brush.TextSecondary}"
                     TextWrapping="Wrap"
                     Margin="0,3,0,10"/>

          <TextBlock Text="Provider Path"
                     FontSize="12"
                     Foreground="{StaticResource Brush.TextMuted}"/>

          <TextBlock Text="{Binding ProviderPath}"
                     FontSize="12"
                     Foreground="{StaticResource Brush.TextSecondary}"
                     TextWrapping="Wrap"
                     Margin="0,3,0,0"/>
        </StackPanel>
      </Border>

      <Border Background="#3A2424"
              BorderBrush="#6B2E2E"
              BorderThickness="1"
              CornerRadius="6"
              Padding="10"
              Margin="0,0,0,16">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasError}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource Brush.TextPrimary}"
                   TextWrapping="Wrap"/>
      </Border>

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,8,0,0">
        <Button Content="Cancel"
                Style="{StaticResource SecondaryButton}"
                Width="110"
                Height="36"
                Margin="0,0,10,0"
                IsCancel="True"
                Click="CancelButton_Click"/>

        <Button Content="Save Changes"
                Style="{StaticResource PrimaryButton}"
                Width="140"
                Height="36"
                IsDefault="True"
                Click="SaveButton_Click"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
