<Window x:Class="Deadbelt.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding ApplicationName}"
        Width="1280"
        Height="800"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}">

  <Window.Resources>
    <Style x:Key="NavigationButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="14,0"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
            </Border>

            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#30363D"/>
                <Setter Property="Foreground"
                                        Value="{StaticResource Brush.TextPrimary}"/>
              </Trigger>

              <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#34402F"/>
                <Setter Property="Foreground"
                                        Value="{StaticResource Brush.AccentGreen}"/>
                <Setter Property="FontWeight"
                                        Value="SemiBold"/>
              </DataTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="96"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="35"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1">

      <Grid Margin="25,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="52"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                        Width="44"
                        Height="44"
                        VerticalAlignment="Center">
          <Border.Background>
            <ImageBrush ImageSource="../Assets/Images/deadbelt-logo.png"
                                    Stretch="Uniform"/>
          </Border.Background>
        </Border>

        <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">

          <TextBlock Text="{Binding ApplicationName}"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

          <TextBlock Text="{Binding ApplicationSubtitle}"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="0,-2,0,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1">

      <!-- Landing Screen -->
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <ScrollViewer.Style>
          <Style TargetType="ScrollViewer">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsWorkspaceOpen}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ScrollViewer.Style>

        <StackPanel Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,40,0,40">

          <TextBlock Text="{Binding WorkspaceStatus}"
                     FontSize="24"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource Brush.TextPrimary}"
                     Margin="0,0,0,16"
                     TextAlignment="Center"/>

          <TextBlock Text="{Binding WelcomeMessage}"
                     FontSize="15"
                     Foreground="{StaticResource Brush.TextSecondary}"
                     TextAlignment="Center"
                     Margin="0,0,0,36"/>

          <Button Content="Create Workspace"
                  Command="{Binding CreateWorkspaceCommand}"
                  Style="{StaticResource PrimaryButton}"
                  Width="350"
                  Height="44"
                  Margin="0,0,0,14"/>

          <Button Content="Open Workspace"
                  Command="{Binding OpenWorkspaceCommand}"
                  Style="{StaticResource SecondaryButton}"
                  Width="350"
                  Height="44"/>

          <Border Background="{StaticResource Brush.Surface}"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="18"
                  Margin="0,24,0,0"
                  Width="420"
                  HorizontalAlignment="Center">

            <StackPanel>
              <StackPanel Margin="0,0,0,14">
                <TextBlock Text="Recent Workspaces"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"/>

                <TextBlock Text="Reopen a workspace without browsing."
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,14,0,0">
                  <Button Content="Open Selected"
                          Command="{Binding OpenRecentWorkspaceCommand}"
                          Style="{StaticResource SecondaryButton}"
                          Width="120"
                          Height="36"
                          Margin="0,0,8,0"/>

                  <Button Content="Remove"
                          Command="{Binding RemoveRecentWorkspaceCommand}"
                          Style="{StaticResource SecondaryButton}"
                          Width="90"
                          Height="36"/>
                </StackPanel>
              </StackPanel>

              <TextBlock Text="No recent workspaces yet. Create or open a workspace to add it here."
                         FontSize="13"
                         Foreground="{StaticResource Brush.TextMuted}"
                         TextWrapping="Wrap">

                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding HasRecentWorkspaces}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>

              <ListBox ItemsSource="{Binding RecentWorkspaces}"
                       SelectedItem="{Binding SelectedRecentWorkspace, Mode=TwoWay}"
                       Background="Transparent"
                       BorderThickness="0"
                       HorizontalContentAlignment="Stretch"
                       MaxHeight="180">

                <ListBox.Style>
                  <Style TargetType="ListBox">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding HasRecentWorkspaces}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </ListBox.Style>

                <ListBox.ItemContainerStyle>
                  <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                  </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{StaticResource Brush.Background}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10">

                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                          <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>

                          <TextBlock Grid.Column="0"
                                     Text="{Binding Name}"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Foreground="{StaticResource Brush.TextPrimary}"
                                     TextTrimming="CharacterEllipsis"/>

                          <TextBlock Grid.Column="1"
                                     Text="{Binding ActionText}"
                                     FontSize="12"
                                     Foreground="{StaticResource Brush.TextMuted}"
                                     Margin="12,0,0,0"
                                     VerticalAlignment="Center">
                            <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.AccentGreen}"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </TextBlock.Style>
                          </TextBlock>
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding Path}"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,4,0,0"/>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding LastOpenedDisplay}"
                                   FontSize="11"
                                   Foreground="{StaticResource Brush.TextMuted}"
                                   Margin="0,4,0,0"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Workspace Shell -->
      <Grid>
        <Grid.Style>
          <Style TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsWorkspaceOpen}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Grid.Style>

        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="240"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Rail -->
        <Border Grid.Column="0"
                        Background="#20252B"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,0,1,0">

          <Grid Margin="18">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                                    Margin="0,0,0,24">

              <TextBlock Text="Workspace"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       Margin="0,0,0,5"/>

              <TextBlock Text="{Binding ActiveWorkspaceName}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>

              <TextBlock Text="{Binding ActiveWorkspaceVersion}"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.AccentGreen}"
                                       Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
              <Button Content="Overview"
                                    Command="{Binding NavigateOverviewCommand}"
                                    Tag="{Binding IsOverviewSelected}"
                                    Style="{StaticResource NavigationButton}"
                                    Margin="0,0,0,6"/>

              <Button Content="Environments"
                                    Command="{Binding NavigateEnvironmentsCommand}"
                                    Tag="{Binding IsEnvironmentsSelected}"
                                    Style="{StaticResource NavigationButton}"
                                    Margin="0,0,0,6"/>

              <Button Content="Providers"
                                    Command="{Binding NavigateProvidersCommand}"
                                    Tag="{Binding IsProvidersSelected}"
                                    Style="{StaticResource NavigationButton}"
                                    Margin="0,0,0,6"/>

              <Button Content="Jobs"
                                    Command="{Binding NavigateJobsCommand}"
                                    Tag="{Binding IsJobsSelected}"
                                    Style="{StaticResource NavigationButton}"
                                    Margin="0,0,0,6"/>

              <Button Content="Settings"
                                    Command="{Binding NavigateSettingsCommand}"
                                    Tag="{Binding IsSettingsSelected}"
                                    Style="{StaticResource NavigationButton}"/>
            </StackPanel>

            <StackPanel Grid.Row="3">
              <TextBlock Text="Actions"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       Margin="0,0,0,10"/>

              <Button Content="Create Workspace"
                                    Command="{Binding CreateWorkspaceCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="36"
                                    Margin="0,0,0,8"/>

              <Button Content="Open Workspace"
                                    Command="{Binding OpenWorkspaceCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="36"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Content Area -->
        <Grid Grid.Column="1">

          <!-- Overview -->
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">

            <ScrollViewer.Style>
              <Style TargetType="ScrollViewer">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsOverviewSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ScrollViewer.Style>

            <Grid Margin="30">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <StackPanel Grid.Row="0"
                                        Margin="0,0,0,25">

                <TextBlock Text="Workspace Dashboard"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"/>

                <TextBlock Text="{Binding ActiveWorkspaceName}"
                                           FontSize="16"
                                           Foreground="{StaticResource Brush.AccentGreen}"
                                           Margin="0,4,0,0"/>
              </StackPanel>

              <UniformGrid Grid.Row="1"
                                         Columns="4"
                                         Margin="0,0,0,25">

                <Border BorderThickness="1"
        CornerRadius="8"
        Padding="18">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
                      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                      <Setter Property="Opacity" Value="1"/>

                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsArchived}" Value="True">
                          <Setter Property="Opacity" Value="0.65"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <StackPanel>

                    <TextBlock Text="Workspace Overview"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   Margin="0,0,0,12"/>

                    <TextBlock Text="Name"
                                                   Foreground="{StaticResource Brush.TextMuted}"
                                                   FontSize="12"/>

                    <TextBlock Text="{Binding ActiveWorkspaceName}"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   FontSize="14"
                                                   Margin="0,2,0,10"/>

                    <TextBlock Text="Version"
                                                   Foreground="{StaticResource Brush.TextMuted}"
                                                   FontSize="12"/>

                    <TextBlock Text="{Binding ActiveWorkspaceVersion}"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   FontSize="14"/>
                  </StackPanel>
                </Border>

                <Border Background="{StaticResource Brush.Surface}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="18"
                                        Margin="0,0,12,0">

                  <StackPanel>
                    <TextBlock Text="Environments"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   Margin="0,0,0,12"/>

                    <TextBlock Text="0"
                                                   FontSize="34"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                    <TextBlock Text="Not configured"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   FontSize="13"/>
                  </StackPanel>
                </Border>

                <Border Background="{StaticResource Brush.Surface}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="18"
                                        Margin="0,0,12,0">

                  <StackPanel>
                    <TextBlock Text="Providers"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding ProviderCount}"
                                                   FontSize="34"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                    <TextBlock Text="Loaded from workspace"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   FontSize="13"/>
                  </StackPanel>
                </Border>

                <Border Background="{StaticResource Brush.Surface}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="18">

                  <StackPanel>
                    <TextBlock Text="Jobs"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"
                                                   Margin="0,0,0,12"/>

                    <TextBlock Text="0"
                                                   FontSize="34"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.TextPrimary}"/>

                    <TextBlock Text="No jobs have run"
                                                   Foreground="{StaticResource Brush.TextSecondary}"
                                                   FontSize="13"/>
                  </StackPanel>
                </Border>
              </UniformGrid>

              <StackPanel Grid.Row="2">

                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <Border Grid.Column="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18"
                Margin="0,0,12,0">

                    <StackPanel>
                      <TextBlock Text="Workspace Location"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Margin="0,0,0,15"/>

                      <TextBlock Text="{Binding ActiveWorkspacePath}"
                           FontSize="14"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap"/>

                      <Separator Margin="0,20,0,20"
                           Background="{StaticResource Brush.Border}"/>

                      <TextBlock Text="Next Steps"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Margin="0,0,0,10"/>

                      <TextBlock Text="Environment management, provider configuration, job execution, and activity history will appear here as those platform capabilities are implemented."
                           FontSize="14"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">

                    <StackPanel>
                      <TextBlock Text="Recent Activity"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Margin="0,0,0,15"/>

                      <TextBlock Text="● Workspace active"
                           Foreground="{StaticResource Brush.AccentGreen}"
                           FontSize="14"
                           Margin="0,0,0,8"/>

                      <TextBlock Text="● No environments configured"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontSize="14"
                           Margin="0,0,0,8"/>

                      <TextBlock Text="● No providers configured"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontSize="14"
                           Margin="0,0,0,8"/>

                      <TextBlock Text="● No jobs have run"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           FontSize="14"/>
                    </StackPanel>
                  </Border>
                </Grid>

                <Border Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="20"
            Margin="0,24,0,0">

                  <StackPanel>
                    <Grid Margin="0,0,0,16">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>

                      <StackPanel Grid.Column="0"
                                  Margin="0,0,16,0">
                        <TextBlock Text="Recent Workspaces"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"/>

                        <TextBlock Text="Quickly reopen a workspace you have created or opened recently."
                               FontSize="13"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>
                      </StackPanel>

                      <StackPanel Grid.Column="1"
                                  Orientation="Horizontal"
                                  VerticalAlignment="Top">
                        <Button Content="Open Selected"
                                Command="{Binding OpenRecentWorkspaceCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="140"
                                Margin="0,0,8,0"/>

                        <Button Content="Remove"
                                Command="{Binding RemoveRecentWorkspaceCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Width="90"/>
                      </StackPanel>
                    </Grid>

                    <TextBlock Text="No recent workspaces yet. Create or open a workspace to add it here."
                       FontSize="13"
                       Foreground="{StaticResource Brush.TextMuted}"
                       TextWrapping="Wrap">

                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Visible"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding HasRecentWorkspaces}" Value="True">
                              <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>

                    <ListBox ItemsSource="{Binding RecentWorkspaces}"
                     SelectedItem="{Binding SelectedRecentWorkspace, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     MaxHeight="220">

                      <ListBox.Style>
                        <Style TargetType="ListBox">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding HasRecentWorkspaces}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </ListBox.Style>

                      <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                          <Setter Property="Padding" Value="0"/>
                          <Setter Property="Margin" Value="0,0,0,8"/>
                          <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                      </ListBox.ItemContainerStyle>

                      <ListBox.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{StaticResource Brush.Background}"
                                BorderBrush="{StaticResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12">

                            <Grid>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="Auto"/>
                              </Grid.ColumnDefinitions>

                              <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.TextPrimary}"/>

                                <TextBlock Text="{Binding LastOpenedDisplay}"
                                               FontSize="12"
                                               Foreground="{StaticResource Brush.TextMuted}"
                                               Margin="0,4,0,0"/>
                              </StackPanel>

                              <TextBlock Grid.Column="1"
                                           Text="{Binding Path}"
                                           FontSize="12"
                                           Foreground="{StaticResource Brush.TextSecondary}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Margin="18,0,18,0"/>

                              <TextBlock Grid.Column="2"
                                           Text="{Binding ActionText}"
                                           FontSize="12"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           VerticalAlignment="Center">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource Brush.AccentGreen}"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>
          </ScrollViewer>

          <!-- Environments -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsEnvironmentsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>

            <Grid Margin="30">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0"
              Margin="0,0,0,25">

                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                  <TextBlock Text="Environments"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"/>

                  <TextBlock Text="Create and manage game server environments in this workspace."
                           FontSize="15"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                  <StackPanel Margin="0,0,16,0"
                              VerticalAlignment="Center">
                    <TextBlock Text="Search"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"
                               Margin="0,0,0,4"/>

                    <TextBox Text="{Binding EnvironmentSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="240"
                             Height="32"
                             Padding="8,4"
                             VerticalContentAlignment="Center"/>
                  </StackPanel>

                  <StackPanel Margin="0,0,16,0"
                              VerticalAlignment="Center">
                    <TextBlock Text="Status Filter"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"
                               Margin="0,0,0,4"/>

                    <ComboBox ItemsSource="{Binding EnvironmentStatusFilters}"
                              SelectedItem="{Binding SelectedEnvironmentStatusFilter, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              Width="150"
                              Height="32"/>
                  </StackPanel>

                  <Button Content="Create Environment"
                          Command="{Binding CreateEnvironmentCommand}"
                          Style="{StaticResource PrimaryButton}"
                          Width="180"
                          VerticalAlignment="Center"/>
                </StackPanel>
              </Grid>

              <Grid Grid.Row="1">

                <!-- Empty State -->
                <Border Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="30"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top">

                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Visible"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasEnvironments}" Value="True">
                          <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="520">

                    <TextBlock Text="No environments configured"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Create your first environment to begin organizing game server configuration, providers, jobs, and future deployment state."
                               FontSize="15"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,12,0,24"/>

                    <Button Content="Create Environment"
                            Command="{Binding CreateEnvironmentCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="190"/>
                  </StackPanel>
                </Border>

                <!-- Filtered Empty State -->
                <Border Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="30"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top">

                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <MultiDataTrigger>
                          <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding HasEnvironments}" Value="True"/>
                            <Condition Binding="{Binding HasVisibleEnvironments}" Value="False"/>
                          </MultiDataTrigger.Conditions>
                          <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>

                  <StackPanel HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Width="520">

                    <TextBlock Text="No environments match the current filter or search"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Change the status filter or search text to view other environments in this workspace."
                               FontSize="15"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0"/>
                  </StackPanel>
                </Border>

                <!-- Environment List and Detail -->
                <Grid>
                  <Grid.Style>
                    <Style TargetType="Grid">
                      <Setter Property="Visibility" Value="Collapsed"/>
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasVisibleEnvironments}" Value="True">
                          <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Grid.Style>

                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="1.5*"/>
                  </Grid.ColumnDefinitions>

                  <!-- Environment List -->
                  <ListBox Grid.Column="0"
             ItemsSource="{Binding Environments}"
             SelectedItem="{Binding SelectedEnvironment, Mode=TwoWay}"
             Background="Transparent"
             BorderThickness="0"
             HorizontalContentAlignment="Stretch"
             ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListBox.ItemContainerStyle>
                      <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,12"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                      </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18">

                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="2*"/>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                              <TextBlock Text="{Binding Name}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"/>

                              <TextBlock Text="{Binding Description}"
                                       FontSize="13"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>

                              <TextBlock Text="{Binding EnvironmentPath}"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                    Margin="20,0,0,0">

                              <TextBlock Text="Game Type"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextMuted}"/>

                              <TextBlock Text="{Binding GameType}"
                                       FontSize="14"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Margin="20,0,0,0">

                              <TextBlock Text="Status"
                                         FontSize="12"
                                         Foreground="{StaticResource Brush.TextMuted}"/>

                              <Border CornerRadius="10"
                                      Padding="10,4"
                                      HorizontalAlignment="Left"
                                      Margin="0,6,0,0">

                                <Border.Style>
                                  <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource Brush.Background}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                                    <Setter Property="BorderThickness" Value="1"/>

                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentGreen}"/>
                                      </DataTrigger>

                                      <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                        <Setter Property="Opacity" Value="0.75"/>
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </Border.Style>

                                <TextBlock Text="{Binding StatusDisplay}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Brush.TextPrimary}"/>
                              </Border>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <!-- Environment Detail -->
                  <Border Grid.Column="2"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22"
            VerticalAlignment="Top">

                    <StackPanel>
                      <StackPanel Margin="0,0,0,22">

                        <TextBlock Text="Environment Details"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="View and edit basic metadata for the selected environment."
                                   FontSize="13"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,16,0,0">

                          <Button Content="Edit"
                                  Command="{Binding EditEnvironmentCommand}"
                                  Style="{StaticResource SecondaryButton}"
                                  Width="90"
                                  Margin="0,0,8,0"/>

                          <Button Content="Archive"
                                  Command="{Binding ArchiveEnvironmentCommand}"
                                  Style="{StaticResource SecondaryButton}"
                                  Width="100"
                                  Margin="0,0,8,0"/>

                          <Button Content="Restore"
                                  Command="{Binding RestoreEnvironmentCommand}"
                                  Width="100">
                            <Button.Style>
                              <Style TargetType="Button"
                                     BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding SelectedEnvironment.IsArchived}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Button.Style>
                          </Button>
                        </StackPanel>
                      </StackPanel>

                      <Border Background="{StaticResource Brush.Background}"
                              BorderBrush="{StaticResource Brush.Border}"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="10"
                              Margin="0,0,0,18">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding SelectedEnvironment.IsArchived}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>

                        <TextBlock Text="{Binding SelectedEnvironment.ArchivedStateMessage}"
                                   FontSize="12"
                                   Foreground="{StaticResource Brush.TextSecondary}"
                                   TextWrapping="Wrap"/>
                      </Border>

                      <TextBlock Text="Name"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}"/>

                      <TextBlock Text="{Binding SelectedEnvironment.Name}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0,3,0,14"/>

                      <TextBlock Text="Description"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}"/>

                      <TextBlock Text="{Binding SelectedEnvironment.Description}"
                       FontSize="14"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       TextWrapping="Wrap"
                       Margin="0,3,0,14"/>

                      <TextBlock Text="Game Type"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}"/>

                      <TextBlock Text="{Binding SelectedEnvironment.GameType}"
                       FontSize="14"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0,3,0,14"/>

                      <TextBlock Text="Status"
                                 FontSize="12"
                                 Foreground="{StaticResource Brush.TextMuted}"/>

                      <Border CornerRadius="10"
                              Padding="10,4"
                              HorizontalAlignment="Left"
                              Margin="0,5,0,14">

                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource Brush.Background}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                            <Setter Property="BorderThickness" Value="1"/>

                            <Style.Triggers>
                              <DataTrigger Binding="{Binding SelectedEnvironment.IsActive}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentGreen}"/>
                              </DataTrigger>

                              <DataTrigger Binding="{Binding SelectedEnvironment.IsArchived}" Value="True">
                                <Setter Property="Opacity" Value="0.75"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>

                        <TextBlock Text="{Binding SelectedEnvironment.StatusDisplay}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Brush.TextPrimary}"/>
                      </Border>

                      <TextBlock Text="Environment ID"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}"/>

                      <TextBlock Text="{Binding SelectedEnvironment.Id}"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       TextWrapping="Wrap"
                       Margin="0,3,0,14"/>

                      <TextBlock Text="Environment Path"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}"/>

                      <TextBlock Text="{Binding SelectedEnvironment.EnvironmentPath}"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       TextWrapping="Wrap"
                       Margin="0,3,0,14"/>

                      <TextBlock Text="Created UTC"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}"/>

                      <TextBlock Text="{Binding SelectedEnvironment.CreatedUtcDisplay}"
                       FontSize="14"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0,3,0,14"/>

                      <TextBlock Text="Version"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextMuted}"/>

                      <TextBlock Text="{Binding SelectedEnvironment.Version}"
                       FontSize="14"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0,3,0,0"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Grid>
          </Grid>

          <!-- Providers -->
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
              <Style TargetType="ScrollViewer">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsProvidersSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ScrollViewer.Style>

            <Grid Margin="30">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0"
                    Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                  <TextBlock Text="Providers"
                             FontSize="28"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.TextPrimary}"/>

                  <TextBlock Text="Create, edit, archive, and restore Provider metadata for the active Workspace."
                             FontSize="15"
                             Foreground="{StaticResource Brush.TextSecondary}"
                             Margin="0,6,0,0"
                             TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Create Provider"
                        Command="{Binding CreateProviderCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="160"
                        Height="36"
                        VerticalAlignment="Center"/>
              </Grid>

              <Grid Grid.Row="1">
                <Grid.Style>
                  <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding HasProviders}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="2*"/>
                  <ColumnDefinition Width="24"/>
                  <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Provider List -->
                <ListBox Grid.Column="0"
                         ItemsSource="{Binding Providers}"
                         SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">

                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                      <Setter Property="Padding" Value="0"/>
                      <Setter Property="Margin" Value="0,0,0,12"/>
                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                  </ListBox.ItemContainerStyle>

                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{StaticResource Brush.Surface}"
                              BorderBrush="{StaticResource Brush.Border}"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="18">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                <Setter Property="Opacity" Value="0.65"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>

                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                          </Grid.ColumnDefinitions>

                          <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding ProviderPath}"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextMuted}"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0"/>
                          </StackPanel>

                          <StackPanel Grid.Column="1"
                                      Margin="20,0,0,0">

                            <TextBlock Text="Provider Type"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextMuted}"/>

                            <TextBlock Text="{Binding ProviderTypeDisplay}"
                                       FontSize="14"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                          </StackPanel>

                          <StackPanel Grid.Column="2"
                                      Margin="20,0,0,0">

                            <TextBlock Text="Status"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.TextMuted}"/>

                            <Border CornerRadius="10"
                                    Padding="10,4"
                                    HorizontalAlignment="Left"
                                    Margin="0,6,0,0">
                              <Border.Style>
                                <Style TargetType="Border">
                                  <Setter Property="Background" Value="{StaticResource Brush.Background}"/>
                                  <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                                  <Setter Property="BorderThickness" Value="1"/>

                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDraft}" Value="True">
                                      <Setter Property="BorderBrush" Value="#8B949E"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsConfigured}" Value="True">
                                      <Setter Property="Background" Value="#1F3326"/>
                                      <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentGreen}"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                                      <Setter Property="BorderBrush" Value="#6E7681"/>
                                      <Setter Property="Opacity" Value="0.85"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                      <Setter Property="Background" Value="#3A1F1F"/>
                                      <Setter Property="BorderBrush" Value="#F85149"/>
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                      <Setter Property="BorderBrush" Value="#6E7681"/>
                                      <Setter Property="Opacity" Value="0.75"/>
                                    </DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </Border.Style>

                              <TextBlock Text="{Binding StatusDisplay}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         Foreground="{StaticResource Brush.TextPrimary}"/>
                            </Border>
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <!-- Provider Detail -->
                <Border Grid.Column="2"
                        Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="22"
                        VerticalAlignment="Top">

                  <StackPanel>
                    <StackPanel Margin="0,0,0,22">
                      <TextBlock Text="Provider Details"
                                 FontSize="22"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource Brush.TextPrimary}"
                                 TextWrapping="Wrap"/>

                      <TextBlock Text="View Provider metadata loaded from Workspace storage."
                                 FontSize="13"
                                 Foreground="{StaticResource Brush.TextSecondary}"
                                 TextWrapping="Wrap"
                                 Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,18">
                      <Button Content="Edit"
                              Command="{Binding EditProviderCommand}"
                              Style="{StaticResource SecondaryButton}"
                              Width="90"
                              Height="34"
                              Margin="0,0,8,0"/>

                      <Button Content="Archive"
                              Command="{Binding ArchiveProviderCommand}"
                              Style="{StaticResource SecondaryButton}"
                              Width="100"
                              Height="34"
                              Margin="0,0,8,0"/>

                      <Button Content="Restore"
                              Command="{Binding RestoreProviderCommand}"
                              Width="100"
                              Height="34">
                        <Button.Style>
                          <Style TargetType="Button"
                                 BasedOn="{StaticResource SecondaryButton}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding SelectedProvider.IsArchived}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Button.Style>
                      </Button>
                    </StackPanel>

                    <Border Background="{StaticResource Brush.Background}"
                            BorderBrush="{StaticResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,18">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedProvider.IsArchived}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>

                      <TextBlock Text="{Binding SelectedProvider.ArchivedStateMessage}"
                                 FontSize="12"
                                 Foreground="{StaticResource Brush.TextSecondary}"
                                 TextWrapping="Wrap"/>
                    </Border>

                    <TextBlock Text="Name"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"/>

                    <TextBlock Text="{Binding SelectedProvider.Name}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,3,0,14"/>

                    <TextBlock Text="Provider Type"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"/>

                    <TextBlock Text="{Binding SelectedProvider.ProviderTypeDisplay}"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0,3,0,14"/>

                    <TextBlock Text="Status"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"/>

                    <Border CornerRadius="10"
                            Padding="10,4"
                            HorizontalAlignment="Left"
                            Margin="0,5,0,14">
                      <Border.Style>
                        <Style TargetType="Border">
                          <Setter Property="Background" Value="{StaticResource Brush.Background}"/>
                          <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                          <Setter Property="BorderThickness" Value="1"/>

                          <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedProvider.IsDraft}" Value="True">
                              <Setter Property="BorderBrush" Value="#8B949E"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding SelectedProvider.IsConfigured}" Value="True">
                              <Setter Property="Background" Value="#1F3326"/>
                              <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentGreen}"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding SelectedProvider.IsDisabled}" Value="True">
                              <Setter Property="BorderBrush" Value="#6E7681"/>
                              <Setter Property="Opacity" Value="0.85"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding SelectedProvider.IsError}" Value="True">
                              <Setter Property="Background" Value="#3A1F1F"/>
                              <Setter Property="BorderBrush" Value="#F85149"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding SelectedProvider.IsArchived}" Value="True">
                              <Setter Property="BorderBrush" Value="#6E7681"/>
                              <Setter Property="Opacity" Value="0.75"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </Border.Style>

                      <TextBlock Text="{Binding SelectedProvider.StatusDisplay}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource Brush.TextPrimary}"/>
                    </Border>

                    <TextBlock Text="Provider ID"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"/>

                    <TextBlock Text="{Binding SelectedProvider.Id}"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,3,0,14"/>

                    <TextBlock Text="Provider Path"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"/>

                    <TextBlock Text="{Binding SelectedProvider.ProviderPath}"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,3,0,14"/>

                    <TextBlock Text="Workspace Path"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"/>

                    <TextBlock Text="{Binding SelectedProvider.WorkspacePath}"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,3,0,14"/>

                    <TextBlock Text="Created UTC"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"/>

                    <TextBlock Text="{Binding SelectedProvider.CreatedUtcDisplay}"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0,3,0,14"/>

                    <TextBlock Text="Version"
                               FontSize="12"
                               Foreground="{StaticResource Brush.TextMuted}"/>

                    <TextBlock Text="{Binding SelectedProvider.Version}"
                               FontSize="14"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               Margin="0,3,0,0"/>
                  </StackPanel>
                </Border>
              </Grid>

              <!-- Empty Provider State -->
              <Border Grid.Row="1"
                      Background="{StaticResource Brush.Surface}"
                      BorderBrush="{StaticResource Brush.Border}"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="40"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Top">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding HasProviders}" Value="False">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>

                <StackPanel HorizontalAlignment="Center"
                            Width="520">
                  <TextBlock Text="No Providers Found"
                             FontSize="24"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             TextAlignment="Center"
                             TextWrapping="Wrap"/>

                  <TextBlock Text="Create your first Provider to define a Workspace-level host, tool, service, or integration that future Environment workflows can use."
                             FontSize="15"
                             Foreground="{StaticResource Brush.TextSecondary}"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             Margin="0,12,0,24"/>

                  <Button Content="Create Provider"
                          Command="{Binding CreateProviderCommand}"
                          Style="{StaticResource PrimaryButton}"
                          Width="170"/>
                </StackPanel>
              </Border>
            </Grid>
          </ScrollViewer>

          <!-- Jobs Placeholder -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsJobsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>

            <StackPanel Width="520"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
              <TextBlock Text="Jobs"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       TextAlignment="Center"/>

              <TextBlock Text="Job execution is not implemented yet."
                                       FontSize="15"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextAlignment="Center"
                                       Margin="0,12,0,0"/>
            </StackPanel>
          </Grid>

          <!-- Settings Placeholder -->
          <Grid>
            <Grid.Style>
              <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Grid.Style>

            <StackPanel Width="520"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
              <TextBlock Text="Settings"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.TextPrimary}"
                                       TextAlignment="Center"/>

              <TextBlock Text="Workspace settings are not implemented yet."
                                       FontSize="15"
                                       Foreground="{StaticResource Brush.TextSecondary}"
                                       TextAlignment="Center"
                                       Margin="0,12,0,0"/>
            </StackPanel>
          </Grid>
        </Grid>
      </Grid>
    </Grid>

    <Border Grid.Row="2"
        Background="{StaticResource Brush.Surface}"
        BorderBrush="{StaticResource Brush.Border}"
        BorderThickness="0,1,0,0"
        Padding="16,0,16,0">

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource Brush.TextSecondary}"
                   FontSize="12"
                   VerticalAlignment="Center"/>

        <TextBlock Grid.Column="1"
                   Text="{Binding ApplicationVersion}"
                   Foreground="{StaticResource Brush.TextMuted}"
                   FontSize="12"
                   VerticalAlignment="Center"
                   Margin="24,0,0,0"/>
      </Grid>
    </Border>
  </Grid>
</Window>
